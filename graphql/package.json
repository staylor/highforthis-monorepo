{
  "name": "@highforthis/graphql",
  "version": "1.0.0",
  "license": "UNLICENSED",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "dependencies": {
    "@apollo/server": "5.4.0",
    "@google-cloud/storage": "7.19.0",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "7.4.1",
    "bcryptjs": "^3.0.3",
    "compression": "1.8.1",
    "cors": "2.8.6",
    "cron": "4.4.0",
    "express": "5.2.1",
    "ffprobe": "1.1.2",
    "ffprobe-static": "3.1.0",
    "graphql": "16.13.0",
    "jsonwebtoken": "^9.0.3",
    "lodash.merge": "4.6.2",
    "mkdirp": "3.0.1",
    "morgan": "1.10.1",
    "multer": "2.0.2",
    "musicmetadata": "2.0.5",
    "sharp": "0.34.5",
    "slugify": "1.6.6"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "dotenv-cli": "11.0.0",
    "esbuild": "0.27.3",
    "jsdom": "^28.1.0",
    "npm-run-all": "4.1.5",
    "pm2": "6.0.14",
    "prisma": "7.4.1",
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "scripts": {
    "dev": "NODE_OPTIONS='--disable-warning=DEP0040' tsx watch --env-file=.env src/index.ts",
    "prod": "run-s prod:*",
    "prod:stop": "pm2 stop pm2.config.cjs",
    "prod:clean": "rimraf lib",
    "prod:generate": "prisma generate",
    "prod:build": "esbuild src/index.ts --packages=external --bundle --platform=node --target=node24 --format=esm --outfile=lib/index.js",
    "prod:start": "pm2 start pm2.config.cjs",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e .env -- prisma migrate dev",
    "db:push": "dotenv -e .env -- prisma db push",
    "db:studio": "dotenv -e .env -- prisma studio",
    "db:migrate-from-mongo": "tsx --env-file=.env tools/migrate-from-mongo.ts",
    "tools:script:dev": "tsx --env-file=.env",
    "tools:script:prod": "tsx --env-file=.env.production",
    "typecheck": "tsc"
  }
}
