{
  "name": "@highforthis/graphql",
  "version": "1.0.0",
  "license": "UNLICENSED",
  "type": "module",
  "dependencies": {
    "@apollo/server": "4.11.3",
    "dotenv": "17.3.1",
    "@google-cloud/storage": "7.15.1",
    "bcrypt": "5.1.1",
    "body-parser": "1.20.3",
    "compression": "1.8.0",
    "cors": "2.8.5",
    "cron": "3.5.0",
    "dataloader": "2.2.3",
    "express": "4.21.2",
    "ffprobe": "1.1.2",
    "ffprobe-static": "3.1.0",
    "graphql": "16.10.0",
    "jwt-simple": "0.5.6",
    "lodash.merge": "4.6.2",
    "mkdirp": "3.0.1",
    "mongodb": "6.13.0",
    "morgan": "1.10.0",
    "multer": "1.4.5-lts.1",
    "musicmetadata": "2.0.5",
    "node-fetch": "3.3.2",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "sharp": "0.33.5",
    "slugify": "1.6.6"
  },
  "devDependencies": {
    "dotenv-cli": "11.0.0",
    "esbuild": "0.25.0",
    "npm-run-all": "4.1.5",
    "pm2": "6.0.5",
    "rimraf": "6.0.1",
    "tsx": "4.19.2",
    "typescript": "5.7.3"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prod": "run-s prod:*",
    "prod:stop": "pm2 stop pm2.config.cjs",
    "prod:clean": "rimraf lib",
    "prod:build": "esbuild src/index.ts --packages=external --bundle --platform=node --target=node20.11.1 --format=esm --outfile=lib/index.js",
    "prod:start": "pm2 start pm2.config.cjs",
    "tools:database:data": "pnpm tools:database:dump && pnpm tools:database:restore",
    "tools:database:dump": "dotenv -e .env.production -- sh ./tools/database/dump",
    "tools:database:restore": "sh ./tools/database/restore",
    "tools:script:dev": "dotenv -- tsx",
    "tools:script:prod": "dotenv -e .env.production -- tsx",
    "typecheck": "tsc"
  }
}
