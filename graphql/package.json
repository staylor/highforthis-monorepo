{
  "name": "@highforthis/graphql",
  "packageManager": "pnpm@10.30.1",
  "version": "1.0.0",
  "license": "UNLICENSED",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "dependencies": {
    "@apollo/server": "5.4.0",
    "@google-cloud/storage": "7.19.0",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "7.4.1",
    "bcryptjs": "^3.0.3",
    "compression": "1.8.1",
    "cors": "2.8.6",
    "cron": "4.4.0",
    "express": "5.2.1",
    "ffprobe": "1.1.2",
    "ffprobe-static": "3.1.0",
    "graphql": "16.13.0",
    "jsonwebtoken": "^9.0.3",
    "mkdirp": "3.0.1",
    "morgan": "1.10.1",
    "multer": "2.0.2",
    "musicmetadata": "2.0.5",
    "sharp": "0.34.5",
    "slugify": "1.6.6",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "esbuild": "0.27.3",
    "jsdom": "^28.1.0",
    "prisma": "7.4.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "scripts": {
    "dev": "NODE_OPTIONS='--disable-warning=DEP0040' tsx watch --env-file-if-exists=.env src/index.ts",
    "build": "prisma generate && esbuild src/index.ts --packages=external --bundle --platform=node --target=node24 --format=esm --outfile=dist/index.js",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:dump": "bash tools/database/dump",
    "db:reset": "bash tools/database/reset",
    "db:migrate-from-mongo": "tsx --env-file-if-exists=.env tools/migrate-from-mongo.ts",
    "tools:script:dev": "tsx --env-file-if-exists=.env",
    "tools:script:prod": "tsx --env-file-if-exists=.env.production",
    "typecheck": "tsc"
  }
}
