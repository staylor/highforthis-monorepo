generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Artist ---

model Artist {
  id                String              @id @default(cuid())
  name              String
  slug              String              @unique
  description       String?
  website           String?
  excludeFromSearch Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  appleMusic        AppleMusicData?
  featuredMedia     ArtistFeaturedMedia[]
  posts             PostArtist[]
  shows             ShowArtist[]
}

model AppleMusicData {
  id        String             @id @default(cuid())
  artistId  String             @unique
  artist    Artist             @relation(fields: [artistId], references: [id], onDelete: Cascade)
  appleId   String?
  url       String?
  genreNames AppleMusicGenre[]
  artwork   AppleMusicArtwork?
}

model AppleMusicGenre {
  id              String         @id @default(cuid())
  appleMusicDataId String
  appleMusicData  AppleMusicData @relation(fields: [appleMusicDataId], references: [id], onDelete: Cascade)
  name            String
}

model AppleMusicArtwork {
  id              String         @id @default(cuid())
  appleMusicDataId String        @unique
  appleMusicData  AppleMusicData @relation(fields: [appleMusicDataId], references: [id], onDelete: Cascade)
  width           Int?
  height          Int?
  url             String?
  bgColor         String?
  textColor1      String?
  textColor2      String?
  textColor3      String?
  textColor4      String?
}

model ArtistFeaturedMedia {
  artistId String
  mediaId  String
  artist   Artist      @relation(fields: [artistId], references: [id], onDelete: Cascade)
  media    MediaUpload @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([artistId, mediaId])
}

// --- Media ---

model MediaUpload {
  id               String              @id @default(cuid())
  title            String?
  description      String?
  originalName     String
  destination      String
  fileName         String
  mimeType         String
  type             String
  fileSize         Int
  // Image fields
  width            Int?
  height           Int?
  caption          String?
  altText          String?
  crops            ImageUploadCrop[]
  // Audio fields
  audioArtists     AudioArtist[]
  album            String?
  audioAlbumArtists AudioAlbumArtist[]
  audioGenres      AudioGenre[]
  year             Int?
  duration         Float?
  audioImages      AudioImage[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  artistFeatured   ArtistFeaturedMedia[]
  venueFeatured    VenueFeaturedMedia[]
  postFeatured     PostFeaturedMedia[]
  podcastAudio     Podcast[]           @relation("PodcastAudio")
  podcastImage     Podcast[]           @relation("PodcastImage")
  podcastSettings  PodcastSettings[]   @relation("PodcastSettingsImage")
}

model ImageUploadCrop {
  id        String      @id @default(cuid())
  mediaId   String
  media     MediaUpload @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  fileName  String
  width     Int
  height    Int
  fileSize  Int
}

model AudioArtist {
  id       String      @id @default(cuid())
  mediaId  String
  media    MediaUpload @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  name     String
}

model AudioAlbumArtist {
  id       String      @id @default(cuid())
  mediaId  String
  media    MediaUpload @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  name     String
}

model AudioGenre {
  id       String      @id @default(cuid())
  mediaId  String
  media    MediaUpload @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  name     String
}

model AudioImage {
  id       String      @id @default(cuid())
  mediaId  String
  media    MediaUpload @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  fileName String
  width    Int
  height   Int
  fileSize Int
}

// --- Podcast ---

model Podcast {
  id          String       @id @default(cuid())
  title       String
  description String       @default("")
  audioId     String?
  imageId     String?
  audio       MediaUpload? @relation("PodcastAudio", fields: [audioId], references: [id])
  image       MediaUpload? @relation("PodcastImage", fields: [imageId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// --- Post ---

model Post {
  id            String             @id @default(cuid())
  title         String
  slug          String             @unique
  editorState   Json?
  summary       String?
  status        String             @default("DRAFT")
  date          DateTime           @default(now())
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  featuredMedia PostFeaturedMedia[]
  artists       PostArtist[]
}

model PostFeaturedMedia {
  postId  String
  mediaId String
  post    Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  media   MediaUpload @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([postId, mediaId])
}

model PostArtist {
  postId   String
  artistId String
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  artist   Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@id([postId, artistId])
}

// --- Show ---

model Show {
  id        String       @id @default(cuid())
  title     String?
  notes     String?
  date      DateTime
  url       String?
  attended  Boolean      @default(false)
  venueId   String
  venue     Venue        @relation(fields: [venueId], references: [id])
  artists   ShowArtist[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model ShowArtist {
  showId   String
  artistId String
  show     Show   @relation(fields: [showId], references: [id], onDelete: Cascade)
  artist   Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@id([showId, artistId])
}

// --- User ---

model User {
  id        String     @id @default(cuid())
  name      String?
  email     String     @unique
  bio       String?
  hash      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  roles     UserRole[]
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String

  @@unique([userId, name])
}

// --- Venue ---

model Venue {
  id                String              @id @default(cuid())
  name              String
  slug              String              @unique
  description       String?
  capacity          String?
  streetAddress     String?
  city              String?
  state             String?
  postalCode        String?
  latitude          Float?
  longitude         Float?
  website           String?
  excludeFromSearch Boolean             @default(false)
  permanentlyClosed Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  featuredMedia     VenueFeaturedMedia[]
  shows             Show[]
}

model VenueFeaturedMedia {
  venueId String
  mediaId String
  venue   Venue       @relation(fields: [venueId], references: [id], onDelete: Cascade)
  media   MediaUpload @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([venueId, mediaId])
}

// --- Video ---

model Video {
  id             String           @id @default(cuid())
  dataId         String           @unique
  slug           String           @unique
  dataType       String           @default("youtube")
  dataPlaylistId String
  year           Int
  publishedAt    DateTime
  publishedISO   String
  title          String
  thumbnails     VideoThumbnail[]
  position       Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model VideoThumbnail {
  id       String @id @default(cuid())
  videoId  String
  video    Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)
  url      String
  width    Int
  height   Int
}

// --- Settings ---

model SiteSettings {
  id            String  @id @default("site")
  siteTitle     String?
  tagline       String?
  siteUrl       String?
  emailAddress  String?
  language      String?
  copyrightText String?
}

model DashboardSettings {
  id               String  @id @default("dashboard")
  googleClientId   String?
  googleTrackingId String?
}

model MediaSettings {
  id    String             @id @default("media")
  crops MediaCropSetting[]
}

model MediaCropSetting {
  id              String        @id @default(cuid())
  mediaSettingsId String
  mediaSettings   MediaSettings @relation(fields: [mediaSettingsId], references: [id], onDelete: Cascade)
  name            String
  width           Int?
  height          Int?
}

model PodcastSettings {
  id              String       @id @default("podcast")
  title           String?
  description     String?
  managingEditor  String?
  copyrightText   String?
  websiteLink     String?
  feedLink        String?
  imageId         String?
  image           MediaUpload? @relation("PodcastSettingsImage", fields: [imageId], references: [id])
  itunesName      String?
  itunesEmail     String?
  generator       String?
  language        String?
  explicit        String?
  category        String?
}
