{
  "compilerOptions": {
    "lib": ["ES2024"],
    "isolatedModules": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "target": "ES2024",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "#/*": ["./src/*"]
    },
    "skipLibCheck": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts", "types/*.ts", "tools/**/*.ts"]
}
