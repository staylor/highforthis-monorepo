{
  "name": "highforthis-monorepo",
  "version": "1.0.0",
  "description": "GraphQL, Web, and Apps",
  "repository": "https://github.com/staylor/highforthis-monorepo",
  "author": "Scott Taylor <scott.c.taylor@mac.com>",
  "license": "private",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "sideEffects": false,
  "type": "module",
  "devDependencies": {
    "@graphql-codegen/cli": "5.0.5",
    "@graphql-codegen/fragment-matcher": "5.1.0",
    "@graphql-codegen/introspection": "4.0.3",
    "@graphql-codegen/schema-ast": "4.1.0",
    "@graphql-codegen/typescript": "4.1.3",
    "@graphql-codegen/typescript-operations": "4.4.1",
    "@graphql-eslint/eslint-plugin": "4.4.0",
    "@lexical/eslint-plugin": "0.24.0",
    "@types/bcrypt": "5.0.2",
    "@types/compression": "1.7.5",
    "@types/cookie-parser": "1.4.8",
    "@types/cors": "2.8.17",
    "@types/express": "5.0.0",
    "@types/ffprobe": "1.1.8",
    "@types/ffprobe-static": "2.0.3",
    "@types/html-escape": "2.0.2",
    "@types/jsdom": "21.1.7",
    "@types/lodash.debounce": "4.0.9",
    "@types/lodash.merge": "4.6.9",
    "@types/morgan": "1.9.9",
    "@types/multer": "1.4.12",
    "@types/musicmetadata": "2.0.9",
    "@types/node": "22.13.4",
    "@types/passport": "1.0.17",
    "@types/passport-jwt": "4.0.1",
    "@types/react": "19.0.9",
    "@types/react-dom": "19.0.3",
    "@wonderboymusic/eslint-config": "1.0.4",
    "esbuild": "0.25.0",
    "eslint-plugin-i18next": "6.1.3",
    "eslint-plugin-tailwindcss": "4.0.0-beta.0",
    "graphql": "16.10.0",
    "jest": "29.7.0",
    "jsdom": "26.0.0",
    "npm-run-all": "4.1.5",
    "prettier": "3.5.1",
    "prettier-plugin-tailwindcss": "0.6.11",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "rimraf": "6.0.1",
    "tsconfig-paths": "4.2.0",
    "tsx": "4.19.2",
    "typescript": "5.7.3"
  },
  "scripts": {
    "codegen": "graphql-codegen && pnpm lint-fix && ./apollo-ios-cli generate",
    "graphql:dev": "pnpm --filter @highforthis/graphql dev",
    "graphql:prod": "pnpm --filter @highforthis/graphql prod",
    "web:dev": "pnpm --filter @highforthis/web dev",
    "web:prod": "pnpm --filter @highforthis/web prod",
    "prod": "pnpm -r prod",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint --report-unused-disable-directives .",
    "lint-fix": "pnpm lint --fix",
    "test:web": "pnpm --filter @highforthis/web test",
    "test:web:watch": "pnpm --filter @highforthis/web test:watch",
    "test:web:update": "pnpm --filter @highforthis/web test:update",
    "typecheck:graphql": "pnpm --filter @highforthis/graphql typecheck",
    "typecheck:web": "pnpm --filter @highforthis/web typecheck"
  },
  "dependencies": {
    "pm2": "6.0.5"
  }
}
