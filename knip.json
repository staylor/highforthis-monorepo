{
  "workspaces": {
    ".": {
      "ignoreDependencies": [
        "esbuild",
        "react",
        "react-dom",
        "tsconfig-paths",
        "tsx",
        "eslint-plugin-tailwindcss"
      ]
    },
    "graphql": {
      "entry": ["tools/**/*.ts"],
      "project": ["src/**/*.ts", "tools/**/*.ts"]
    },
    "web": {
      "project": ["src/**/*.{ts,tsx}"],
      "ignore": ["src/types/graphql.ts"],
      "ignoreDependencies": [
        "i18next-fs-backend",
        "i18next-http-backend",
        "postcss",
        "tailwindcss",
        "@tailwindcss/forms"
      ]
    }
  },
  "ignoreBinaries": ["gsutil"]
}
